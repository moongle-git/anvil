# GEMINI_API_KEY만 필수다. 나머지 키가 없으면 그 자료조사 소스만 건너뛰고 나머지로 진행한다.
# (Hacker News는 인증이 없어 키 없이 항상 수집한다.)

# 필수 — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 선택 — YouTube Data API v3 (Google Cloud Console에서 API 사용 설정 후 API 키 발급)
YOUTUBE_API_KEY=

# 선택 — 네이버 개발자센터(https://developers.naver.com/apps)에서 애플리케이션 등록 후
# "검색" API를 추가하면 발급된다. 둘 다 있어야 네이버 수집이 켜진다 (반쪽 설정은 부재로 취급).
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
