# anvil 프로덕션 환경변수 템플릿 — Phase 9-deploy
#
# 사용법:
#   cp deploy/.env.production.example /opt/anvil/.env.production
#   # 실제 값을 채운 뒤
#   sudo chown anvil:anvil /opt/anvil/.env.production
#   sudo chmod 600 /opt/anvil/.env.production
#
# ⚠️ 이 파일은 systemd 의 EnvironmentFile= 이 읽는다. dotenv(.env) 가 아니다. 규칙이 다르다:
#
#   1. `export ` 접두사를 쓰지 마라. systemd 는 그것을 키 이름의 일부로 읽어
#      `export GEMINI_API_KEY` 라는 이름의 변수가 생긴다 — 앱은 키가 없다고 판단한다.
#   2. `#` 주석은 **줄 맨 앞에서만** 주석이다. `PORT=3000  # 웹 포트` 라고 쓰면
#      값이 `3000  # 웹 포트` 가 된다.
#   3. 값에 공백·따옴표가 있으면 값 전체를 따옴표로 감싸라. systemd 가 한 겹을 벗겨낸다.
#      큰따옴표 안에서는 백슬래시가 이스케이프 문자다 — 값에 `\` 가 들어가면 작은따옴표를 써라.
#   4. `$` 는 확장되지 않는다(셸·dotenv 와 다르다). `$` 가 든 API 키를 이스케이프하지 마라.
#   5. 여러 줄 값은 지원되지 않는다.
#
# ⚠️ 실제 키를 이 `.example` 파일에 적지 마라. `.env` 는 .gitignore 에 있지만
#    `deploy/*.example` 은 커밋된다.

# ── 필수 ────────────────────────────────────────────────────────────────────────
# Gemini API 키. 이것만 필수다.
GEMINI_API_KEY=replace-me

# ── 선택 (자료조사 소스) ────────────────────────────────────────────────────────
# 없으면 해당 소스를 건너뛰고 나머지로 진행한다 (fail-soft, ADR-012).
# Hacker News 는 키가 필요 없다.
YOUTUBE_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 경로 (cwd 추론에 기대지 말고 명시한다) ─────────────────────────────────────
# SQLite DB (ADR-014). 웹과 CLI 가 같은 파일을 열어야 한다 — 어긋나면 웹이 조용히 빈 목록을 보여준다.
ANVIL_DB_PATH=/opt/anvil/data/anvil.db
# 웹이 CLI 를 spawn 할 cwd (ADR-007).
ANVIL_REPO_ROOT=/opt/anvil

# ── 런타임 ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
# next start 는 PORT 를 환경변수로만 읽는다(.env 로는 못 바꾼다 — HTTP 서버가 먼저 뜬다).
PORT=3000

# 참고: 여기 적힌 값은 웹 프로세스가 spawn 하는 CLI(`npm run consult`)에도 그대로 상속된다.
# CLI 의 dotenv 는 이미 설정된 process.env 를 덮어쓰지 않으므로, 서버에 별도의 .env 를 둘 필요가 없다.
