# anvil 엣지 리버스 프록시 (Caddy v2) — Phase 9-deploy
#
# 설치:
#   sudo cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   sudo $EDITOR /etc/caddy/Caddyfile        # 아래 <...> 자리를 실제 값으로 교체
#   sudo caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile
#   sudo systemctl reload caddy
#
# **레포에는 예시만 둔다.** 실제 bcrypt 해시와 실제 도메인은 서버의 /etc/caddy/Caddyfile 에만
# 존재하며 커밋되지 않는다. 이 파일을 실제 값으로 채워서 커밋하지 마라.
#
# 상세 절차는 docs/DEPLOY.md 가 소유한다. 여기서는 설정 자체만 설명한다.

# ── 왜 앱 로그인이 아니라 여기인가 ────────────────────────────────────────────────
# 앱에는 인증이 없다. PRD 가 "사용자 인증·배포·멀티테넌시"를 명시적 비목표로 두고 있고,
# 이 파일은 그 비목표를 **뒤집지 않은 채** 공인 IP 노출을 가능하게 만드는 우회다.
# 앱 코드 수정은 0줄이다. 근거는 ADR(step 4)에 정식으로 남는다. 요지만 옮기면:
#
#  1. basic auth 는 여기서 끊기므로 Next 프로세스가 아예 실행되지 않는다. 앱 로그인은 반대로
#     로그인 엔드포인트가 공개되어야 동작하므로 공격 표면이 오히려 늘어난다.
#  2. CLI(`npm run consult`)에는 세션이 없다. 인증을 앱에 넣으면 웹 경로에만 존재하고,
#     DB 에는 세션 없는 프로세스가 만든 run 이 계속 쌓인다 — 단일 진실 공급원(ADR-014)이
#     두 개의 접근 모델을 갖게 된다.
#  3. DB 에 사용자 개념이 없다(runs·steps·artifacts·usage 어디에도). 운영자 한 명 전제에서
#     user_id 는 항상 같은 값인 컬럼이고, 스코프 검사는 항상 참인 조건이다.
#
# 막으려는 것은 이론이 아니라 청구서다: 인증 없이 공인 IP 에 올리면 누구나
# `POST /api/runs` 로 운영자의 Gemini 키를 태울 수 있다. run 하나는 실비가 나가며
# 그중 65% 가 context-hunter 하나에서 발생한다(ADR-016 실측).

# ── basic auth 의 한계 (알고 선택한 것이다) ──────────────────────────────────────
# 허술해 보인다면 맞다. 아래를 알고도 이 범위를 택했다:
#
#  * **단일 공유 자격증명이다.** 앱은 누가 접속했는지 모르고, 알 필요도 없다(운영자 1명 전제).
#    사람이 늘면 이 파일이 아니라 별도 phase 가 답이다.
#  * **base64 는 암호화가 아니다.** Authorization 헤더는 매 요청에 실려 가고 디코딩은
#    누구나 한다. 즉 **TLS 가 없으면 사실상 평문 비밀번호를 반복 전송하는 것이다.**
#    이 설정에서 HTTPS 는 선택이 아니라 성립 조건이다 — 아래 "HTTP 로 내리지 마라" 참조.
#  * **표준적인 로그아웃이 없다.** 브라우저가 자격증명을 캐시하며, 끊으려면 비밀번호를
#    바꾸고 reload 하는 것이 사실상 유일한 방법이다.
#  * **rate limit 이 없다.** Caddy 표준 배포판에는 rate limit 디렉티브가 없고, 그것 때문에
#     커스텀 빌드를 하지는 않는다. 대응은 **길고 랜덤한 비밀번호**다(20자 이상 권장).
#     bcrypt 검증 자체가 요청당 수십 ms 를 쓰므로 무차별 대입의 실효 속도도 낮다.

# ── 호스트 이름 ────────────────────────────────────────────────────────────────
# 도메인이 있으면 그 도메인을 쓴다:            anvil.example.com {
# 도메인이 없으면 sslip.io 폴백을 쓴다:        203.0.113.10.sslip.io {
#
# **도메인이 없다고 배포를 못 하는 것이 아니다.** sslip.io 는 <IP>.sslip.io 형태의 이름을
# 그 IP 로 그대로 해석해주는 공개 DNS 다. 실재하는 이름이므로 Let's Encrypt 의 HTTP-01
# 챌린지가 통과하고 **정식 인증서가 발급된다** — self-signed 도 아니고 내부 CA 도 아니다.
# 나중에 도메인이 생기면 아래 첫 줄만 교체하고 reload 하면 된다. 그 외에는 아무것도 안 바뀐다.
# (IP 리터럴을 그대로 쓰면 안 된다. Let's Encrypt 는 IP 에 인증서를 발급하지 않으므로
#  Caddy 가 HTTP 로만 서비스하게 되고, 그 순간 위의 "평문 비밀번호" 문제가 현실이 된다.)
<도메인 또는 <공인IP>.sslip.io> {
	# ── 접근 통제 ──────────────────────────────────────────────────────────────
	# **사이트 블록 최상단에 matcher 없이 둔다. 그래서 전 경로에 적용된다** — 페이지도,
	# /api/runs 도, /api/runs/{id}/rerun 도 전부 401 로 끊긴다. 이것이 이 설정의 목적이다.
	#
	# **특정 경로만 여는 matcher 를 추가하지 마라.** POST /api/runs 하나가 뚫리면
	# 이 파일은 아무것도 막지 못한 것이 된다. 현재 열려 있는 쓰기 경로는 이만큼이다:
	#   POST   /api/runs                  (새 run 생성 → 파이프라인 spawn — 돈이 나가는 경로)
	#   POST   /api/runs/{id}/resume      (중단 지점부터 재개 → spawn)
	#   POST   /api/runs/{id}/rerun       (자료조사부터 새 run 포크 → spawn)
	#   POST   /api/runs/{id}/answers     (인터뷰 답변 제출)
	#   DELETE /api/runs/{id}             (삭제 — CASCADE, 되돌릴 수 없다)
	#
	# 사용자명 규약: anvil (운영자 1명 전제이므로 사람 이름을 쓰지 않는다)
	#
	# 해시 생성 — 서버에서 실행하고 출력 한 줄을 아래 자리에 붙여 넣는다:
	#   caddy hash-password --plaintext '<20자 이상 랜덤 비밀번호>'
	# 비밀번호 생성이 필요하면:
	#   openssl rand -base64 24
	#
	# 해시는 `$2a$14$...` 꼴이며 `$` 를 포함한다. Caddyfile 에서 `$` 는 특별한 문자가 아니므로
	# (Caddy 의 환경변수 치환 문법은 `{env.FOO}` 다) 이스케이프 없이 그대로 붙여 넣으면 된다.
	# 평문 비밀번호를 이 자리에 적지 마라 — 반드시 해시다.
	#
	# **디렉티브 이름이 Caddy 버전에 따라 다르다.** `basic_auth` 는 **2.8 이상**의 이름이고,
	# 그 이전은 `basicauth`(언더스코어 없음)다. 틀리면 설정 파싱이 실패해 **Caddy 가 아예
	# 뜨지 않는다** — 접근이 막히는 게 아니라 사이트 전체가 내려간다.
	# 설치된 버전을 먼저 확인하라: caddy version
	basic_auth {
		anvil <caddy hash-password 출력을 여기에>
	}

	# ── 업스트림 ───────────────────────────────────────────────────────────────
	# systemd 유닛(deploy/anvil-web.service)이 띄우는 next start 다.
	# 포트는 /opt/anvil/.env.production 의 PORT 와 일치해야 한다(기본 3000).
	# next start 는 기본적으로 모든 인터페이스에 바인딩하므로, 방화벽에서 3000 을 외부에
	# 열어두면 프록시를 우회해 직접 접속할 수 있다. **80/443 만 열어라** (docs/DEPLOY.md).
	reverse_proxy localhost:3000 {
		# 파이프라인 진행 폴링은 2초 간격의 짧은 요청이라 기본 타임아웃으로 충분하다(ADR-007).
		# 다만 리포트 응답이 수십 KB 이므로 버퍼링 없이 그대로 흘려보낸다(Caddy 기본값).
		#
		# 클라이언트 IP 를 업스트림에 전달한다. Caddy 는 X-Forwarded-For/Proto/Host 를
		# 기본으로 붙이지만, 앱은 이 헤더를 읽지 않는다 — journalctl 로 접근 출처를 볼 때만 쓴다.
	}

	# ── TLS ───────────────────────────────────────────────────────────────────
	# **명시적 tls 디렉티브를 두지 않는다.** Caddy 는 사이트 주소가 호스트 이름이면
	# 자동으로 Let's Encrypt 인증서를 받고 80 → 443 리다이렉트를 건다. 그 기본값이 정확히
	# 우리가 원하는 것이다.
	#
	# **HTTP(:80)로 서비스하는 블록을 추가하지 마라.** `http://` 접두사를 붙이거나
	# `auto_https off` 를 켜는 순간 basic auth 자격증명이 평문으로 흐른다(위 "한계" 참조).
	# 인증서 발급이 실패한다면 그것은 끄고 넘어갈 문제가 아니라 고칠 문제다:
	#   - 80/443 이 방화벽에서 열려 있는가 (HTTP-01 챌린지는 80 을 쓴다)
	#   - 사이트 주소가 이 서버 IP 로 해석되는가 (dig +short <호스트이름>)
	#   - Let's Encrypt rate limit 에 걸렸는가 (journalctl -u caddy -f)
	#
	# 인증서 발급 실패를 디버깅할 때만 staging 을 쓴다. 운영에서는 반드시 지워라 —
	# staging 인증서는 브라우저가 신뢰하지 않는다.
	#   tls {
	#       ca https://acme-staging-v02.api.letsencrypt.org/directory
	#   }

	# 접근 로그. 401 이 반복되면 누군가 문을 두드리고 있다는 뜻이다.
	log {
		output file /var/log/caddy/anvil.log
		format json
	}
}
