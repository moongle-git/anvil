# dependencies
node_modules/

# environment variables (API keys)
.env
.env.local
.env.*.local
# 서버의 실제 운영 환경변수 (systemd EnvironmentFile — deploy/.env.production.example 이 템플릿).
# 레포 루트 안에 놓이므로 명시적으로 무시해야 한다. 위 .env.*.local 패턴은 이 이름을 잡지 못하고,
# 그러면 scripts/deploy.sh 의 워킹트리 청결 검사가 매번 걸린다. API 키가 들어 있는 파일이다.
.env.production

# build output
dist/
tsconfig.tsbuildinfo

# Next.js (web workspace)
web/.next/
web/out/
web/next-env.d.ts

# pipeline run outputs (루트만 — web/src/app/api/runs/ 같은 소스 경로는 무시하지 않는다)
/runs/

# SQLite DB (WAL 모드라 -wal/-shm 파일이 함께 생긴다) — ADR-014
/data/

# test coverage
coverage/

# phase execution outputs
phases/**/phase*-output.json
phases/**/step*-output.json

# editor / OS
.DS_Store
.idea/
.vscode/

# logs
*.log
